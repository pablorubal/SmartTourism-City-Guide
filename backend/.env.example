# Application
APP_NAME=SmartTourism City Guide
APP_VERSION=0.1.0
DEBUG=False

# API
API_V1_STR=/api/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smartourism

# Orion Context Broker
ORION_URL=http://localhost:1026
ORION_TENANT=smartourism
ORION_VERSION=v2

# QuantumLeap
QUANTUMLEAP_URL=http://localhost:8668

# Redis
REDIS_URL=redis://localhost:6379/0

# ML Models
MODEL_PATH=/models
ENABLE_ML=True

# Ollama LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Default Location (A Coruña)
DEFAULT_LAT=43.3622
DEFAULT_LON=-8.3886

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","*"]
