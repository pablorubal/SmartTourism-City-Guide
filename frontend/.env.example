# Frontend Environment Variables

# API
VITE_API_URL=http://localhost:8000
VITE_API_v1=http://localhost:8000/api/v1

# WebSocket
VITE_WS_URL=ws://localhost:8000/ws

# Ollama Chat
VITE_OLLAMA_URL=http://localhost:11434

# Default Location (A Coruña)
VITE_DEFAULT_LAT=43.3622
VITE_DEFAULT_LON=-8.3886
VITE_DEFAULT_ZOOM=13

# Feature Flags
VITE_ENABLE_3D=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_SOCIAL_MATCH=true
